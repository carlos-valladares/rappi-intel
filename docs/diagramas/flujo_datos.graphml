<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<graphml xmlns="http://graphml.graphdrawing.org/graphml"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns:y="http://www.yworks.com/xml/graphml"
         xsi:schemaLocation="http://graphml.graphdrawing.org/graphml http://www.yworks.com/xml/schema/graphml/1.1/ygraphml.xsd">

  <key for="node" id="d0" yfiles.type="nodegraphics"/>
  <key for="edge" id="d1" yfiles.type="edgegraphics"/>

  <graph id="G" edgedefault="directed">

    <!-- Input -->
    <node id="input">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="250" y="20" width="220" height="40"/>
        <y:Fill color="#ECF0F1" transparent="false"/>
        <y:BorderStyle color="#BDC3C7" type="line" width="1.5"/>
        <y:NodeLabel fontFamily="Arial" fontSize="12">config/addresses.json (25 zonas)</y:NodeLabel>
        <y:Shape type="parallelogram"/>
      </y:ShapeNode></data>
    </node>

    <!-- Scraping Rappi -->
    <node id="scrape_rappi">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="60" y="110" width="180" height="60"/>
        <y:Fill color="#FF6900" transparent="false"/>
        <y:BorderStyle color="#CC5500" type="line" width="2.0"/>
        <y:NodeLabel fontFamily="Arial" fontSize="11" fontStyle="bold" textColor="#FFFFFF">Rappi Scraper&#10;API directa + login&#10;Burger King, Carl's Jr</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- Scraping UberEats -->
    <node id="scrape_ue">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="270" y="110" width="180" height="60"/>
        <y:Fill color="#142328" transparent="false"/>
        <y:BorderStyle color="#000000" type="line" width="2.0"/>
        <y:NodeLabel fontFamily="Arial" fontSize="11" fontStyle="bold" textColor="#FFFFFF">UberEats Scraper&#10;getFeedV1 + getStoreV1&#10;McDonald's, BK, OXXO</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- Scraping DiDi -->
    <node id="scrape_didi">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="480" y="110" width="180" height="60"/>
        <y:Fill color="#FF8000" transparent="false"/>
        <y:BorderStyle color="#CC6600" type="line" width="2.0"/>
        <y:NodeLabel fontFamily="Arial" fontSize="11" fontStyle="bold" textColor="#FFFFFF">DiDi Scraper&#10;HTML SSR (1 vez/corrida)&#10;Solo nombre + rating</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- Registros normalizados -->
    <node id="records">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="200" y="220" width="320" height="40"/>
        <y:Fill color="#D5F5E3" transparent="false"/>
        <y:BorderStyle color="#27AE60" type="line" width="1.5"/>
        <y:NodeLabel fontFamily="Arial" fontSize="11">Registros normalizados — _registro_base()</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- CSV raw -->
    <node id="csv">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="40" y="310" width="160" height="40"/>
        <y:Fill color="#FEF9E7" transparent="false"/>
        <y:BorderStyle color="#F39C12" type="line" width="1.5"/>
        <y:NodeLabel fontFamily="Arial" fontSize="11">data/raw/*.csv&#10;(backup por run)</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- JSON raw -->
    <node id="json_raw">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="40" y="370" width="160" height="40"/>
        <y:Fill color="#FEF9E7" transparent="false"/>
        <y:BorderStyle color="#E67E22" type="line" width="1.5"/>
        <y:NodeLabel fontFamily="Arial" fontSize="11">data/raw/*_raw.json&#10;(APIs interceptadas)</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- DuckDB -->
    <node id="duckdb">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="460" y="310" width="200" height="50"/>
        <y:Fill color="#27AE60" transparent="false"/>
        <y:BorderStyle color="#1E8449" type="line" width="2.0"/>
        <y:NodeLabel fontFamily="Arial" fontSize="12" fontStyle="bold" textColor="#FFFFFF">DuckDB&#10;datos_competencia (acumulado)</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- Análisis -->
    <node id="analysis">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="460" y="400" width="200" height="40"/>
        <y:Fill color="#8E44AD" transparent="false"/>
        <y:BorderStyle color="#6C3483" type="line" width="2.0"/>
        <y:NodeLabel fontFamily="Arial" fontSize="12" fontStyle="bold" textColor="#FFFFFF">analysis/report.py&#10;Plotly Charts</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- Report HTML -->
    <node id="html">
      <data key="d0"><y:ShapeNode>
        <y:Geometry x="250" y="490" width="220" height="40"/>
        <y:Fill color="#F1948A" transparent="false"/>
        <y:BorderStyle color="#C0392B" type="line" width="1.5"/>
        <y:NodeLabel fontFamily="Arial" fontSize="12" fontStyle="bold" textColor="#FFFFFF">data/report.html&#10;Dashboard interactivo</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- Edges -->
    <edge id="e1" source="input" target="scrape_rappi">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#FF6900" type="dashed" width="1.5"/></y:PolyLineEdge></data>
    </edge>
    <edge id="e2" source="input" target="scrape_ue">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#142328" type="dashed" width="1.5"/></y:PolyLineEdge></data>
    </edge>
    <edge id="e3" source="input" target="scrape_didi">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#FF8000" type="dashed" width="1.5"/><y:EdgeLabel>solo 1ra zona</y:EdgeLabel></y:PolyLineEdge></data>
    </edge>
    <edge id="e4" source="scrape_rappi" target="records">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#555" type="line" width="1.5"/><y:EdgeLabel>normaliza</y:EdgeLabel></y:PolyLineEdge></data>
    </edge>
    <edge id="e5" source="scrape_ue" target="records">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#555" type="line" width="1.5"/></y:PolyLineEdge></data>
    </edge>
    <edge id="e6" source="scrape_didi" target="records">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#555" type="line" width="1.5"/></y:PolyLineEdge></data>
    </edge>
    <edge id="e7" source="records" target="csv">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#F39C12" type="dashed" width="1.5"/><y:EdgeLabel>save_csv()</y:EdgeLabel></y:PolyLineEdge></data>
    </edge>
    <edge id="e8" source="records" target="json_raw">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#E67E22" type="dashed" width="1.5"/><y:EdgeLabel>save_intercepted()</y:EdgeLabel></y:PolyLineEdge></data>
    </edge>
    <edge id="e9" source="records" target="duckdb">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#27AE60" type="line" width="2.0"/><y:EdgeLabel>ingest_dataframe()</y:EdgeLabel></y:PolyLineEdge></data>
    </edge>
    <edge id="e10" source="duckdb" target="analysis">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#8E44AD" type="line" width="1.5"/><y:EdgeLabel>SELECT *</y:EdgeLabel></y:PolyLineEdge></data>
    </edge>
    <edge id="e11" source="analysis" target="html">
      <data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:LineStyle color="#C0392B" type="line" width="1.5"/><y:EdgeLabel>genera</y:EdgeLabel></y:PolyLineEdge></data>
    </edge>

  </graph>
</graphml>
